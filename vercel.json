{
  "version": 2,
  "functions": {
    "server/api.js": {
      "runtime": "@vercel/node"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/server/api.js"
    },
    {
      "source": "/health",
      "destination": "/server/api.js"
    },
    {
      "source": "/",
      "destination": "/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/$1"
    }
  ]
}
